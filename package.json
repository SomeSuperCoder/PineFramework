{
  "name": "pine-framework",
  "private": true,
  "version": "0.1.0",
  "description": "Pine Script v6 compatible execution and rendering engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils/time": {
      "source": "./src/utils/time.ts",
      "types": "./dist/utils/time.d.ts",
      "import": "./dist/utils/time.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter pine-framework-backend dev\" \"pnpm --filter pine-framework-frontend dev\"",
    "build": "pnpm --filter pine-framework run build:lib && pnpm --filter pine-framework-backend run build && pnpm --filter pine-framework-frontend run build",
    "build:lib": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm -r typecheck",
    "backtest": "pnpm --filter pine-framework-backend backtest"
  },
  "keywords": [
    "pine-script",
    "tradingview",
    "technical-analysis",
    "backtesting"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitest/coverage-v8": "3.2.6",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@jup-ag/api": "^6.0.48"
  }
}

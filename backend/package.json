{
  "name": "pine-framework-backend",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "pine-backtest": "./dist/cli/backtest-cli.js"
  },
  "scripts": {
    "dev": "tsx watch --conditions=source src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "cli:build": "tsc -p tsconfig.build.json",
    "backtest": "node dist/cli/backtest-cli.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "pine-framework": "workspace:*",
    "proper-lockfile": "^4.1.2",
    "socks-proxy-agent": "^10.1.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2"
  }
}
